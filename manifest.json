{
  "manifest_version": 3,
  "name": "Slopstagram",
  "version": "1.0",

  "description": "De-slopifys Instagram by removing distractions to focus on the messaging functionality.",

  "icons": {
    "48": "icons/alien-48.png",
    "96": "icons/alien-96.png"
  },
  
  "permissions": ["activeTab", "tabs", "storage", "scripting"],

  "browser_specific_settings": {
    "gecko": {
      "id": "slopstagram@tabyte.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_icon": "icons/alien-32.png",
    "theme_icons": [
      {
        "light": "icons/alien-32-light.png",
        "dark": "icons/alien-32.png",
        "size": 32
      }
    ],
    "default_title": "Slopstagram",
    "default_popup": "popup/settings.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content_scripts/slopstagram.js"]
    }
  ]
}