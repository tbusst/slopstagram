{
  "manifest_version": 3,
  "name": "Slopstagram",
  "version": "1.0",

  "description": "De-slopifys Instagram by removing distractions to focus on the messaging functionality.",

  "icons": {
    "48": "icons/alien-48.png",
    "96": "icons/alien-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "slopstagram@tabyte.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*instagram.com//*"],
      "js": ["slopstagram.js"]
    }
  ]
}